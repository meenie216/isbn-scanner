# Copy this file to .env and fill in your values before running the deploy.
# Never commit .env to version control.

# ── AWS credentials ────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ── Neon PostgreSQL ────────────────────────────────────────────────────────────
# Sign up free at https://neon.tech
# Use the POOLED connection string (ends in -pooler.ap-southeast-2.aws.neon.tech)
NEON_DB_URL=postgresql://user:password@ep-xxx-pooler.ap-southeast-2.aws.neon.tech/neondb?sslmode=require

# ── OMDB API key ───────────────────────────────────────────────────────────────
# Register free at https://www.omdbapi.com/apikey.aspx (they email it instantly)
OMDB_API_KEY=your_omdb_key_here

# ── Google Books API key (optional) ───────────────────────────────────────────
# https://developers.google.com/books/docs/v1/using#APIKey
# Leave as 'none' to skip — Open Library is used as the primary book source
GOOGLE_BOOKS_API_KEY=none
